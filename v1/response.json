{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$defs": {
    "procedureResource": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "object"
        },
        {
          "type": "array"
        },
        {
          "type": "null"
        }
      ]
    },
    "requestDetails": {
      "type": "object",
      "properties": {
        "request_id": {
          "description": "Id of the request, either the value provided by the client or the autogenerated id.",
          "type": "string",
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9-_.]+$"
        },
        "execution_time": {
          "description": "How long it took to process the request; value is in milliseconds.",
          "type": "number"
        },
        "procedures_execution": {
          "description": "Details regarding each procedure execution.",
          "type": "object",
          "patternProperties": {
            "^[a-zA-Z]{1}[a-zA-Z0-9_]+$": {
              "type": "object",
              "properties": {
                "id": {
                  "description": "Id assigned to the procedure execution.",
                  "type": "string",
                  "maxLength": 128,
                  "pattern": "^[a-zA-Z0-9-_.]+$"
                },
                "procedure": {
                  "description": "Name of the executed procedure.",
                  "type": "string",
                  "maxLength": 128,
                  "pattern": "^[a-zA-Z]{1}[a-zA-Z0-9_]+$"
                },
                "order": {
                  "description": "Order in which the procedure was executed.",
                  "type": "number"
                },
                "timed_out": {
                  "description": "True when the procedure execution time exceeded the allowed time; False otherwise.",
                  "type": "boolean"
                },
                "execution_time": {
                  "description": "How long it took to process the procedure; value is in milliseconds.",
                  "type": "number"
                }
              },
              "required": [
                "id",
                "procedure",
                "order",
                "timed_out",
                "execution_time"
              ],
              "additionalProperties": false
            }
          }
        }
      },
      "additionalProperties": false
    },
    "procedureResult": {
      "description": "A procedure result can be either an error or a successful execution.",
      "oneOf": [
        {
          "description": "Output resource from the procedure execution.",
          "type": "object",
          "properties": {
            "result": {
              "$ref": "#/$defs/procedureResource"
            }
          },
          "required": ["result"],
          "additionalProperties": false
        },
        {
          "description": "Error object when the procedure execution failed.",
          "type": "object",
          "properties": {
            "error": {
              "type": "object",
              "properties": {
                "code": {
                  "description": "Code of the error.",
                  "maxLength": 128,
                  "type": "string"
                },
                "message": {
                  "description": "Additional error information.",
                  "maxLength": 256,
                  "type": "string"
                }
              },
              "required": ["code", "message"]
            }
          },
          "required": ["error"],
          "additionalProperties": false
        }
      ]
    }
  },
  "properties": {
    "protocol": {
      "description": "ORPC protocol version.",
      "const": "v1"
    },
    "api": {
      "description": "API version.",
      "type": "string",
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9-_.\/]+$"
    },
    "procedures": {
      "description": "Collection of procedure results.",
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z]{1}[a-zA-Z0-9_]+$": {
          "$ref": "#/$defs/procedureResult"
        }
      }
    },
    "details": {
      "description": "Additional request processing information when the request provided a [return] option.",
      "$ref": "#/$defs/requestDetails"
    }
  },
  "required": [
    "protocol",
    "api"
  ],
  "additionalProperties": false
}
